# ── Server ────────────────────────────────────────────────
PORT=5000
FLASK_ENV=development

# ── Security ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
TOKEN_EXPIRY_HOURS=24

# ── Database ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=ecommerce

# ── OTP (Twilio) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_EXPIRY_MINUTES=10

# ── Admin seed account ────────────────────────────────────
ADMIN_EMAIL=admin@freshmart.com
ADMIN_PASSWORD=Admin@1234

# ─────────────────────────────────────────────────────────
# INSTAMOJO PAYMENT GATEWAY
# ─────────────────────────────────────────────────────────
#
# WHERE TO GET THESE VALUES:
#   1. Log in at https://www.instamojo.com/
#   2. Go to Settings → Advanced → API & Plugins
#   3. Copy your API Key     → paste as INSTAMOJO_CLIENT_ID
#   4. Copy your Auth Token  → paste as INSTAMOJO_CLIENT_SECRET
#   5. Copy your Private Salt → paste as INSTAMOJO_SALT
#
# TEST (sandbox) credentials are at:
#   https://test.instamojo.com/developers/   (use these while building)
#
# LIVE (production) credentials are at:
#   https://www.instamojo.com/developers/    (switch when ready to go live)
#
INSTAMOJO_CLIENT_ID=your_api_key_here
INSTAMOJO_CLIENT_SECRET=your_auth_token_here
INSTAMOJO_SALT=your_private_salt_here

# Use test URL while developing. Switch to https://api.instamojo.com when live.
INSTAMOJO_BASE_URL=https://test.instamojo.com

# ─────────────────────────────────────────────────────────
# URLS
# ─────────────────────────────────────────────────────────
# APP_URL   = the URL where your Flask backend is reachable from the internet.
#             Instamojo calls /api/payments/webhook on this URL.
#             During development use ngrok: https://abc123.ngrok.io
#             In production use your domain: https://api.yoursite.com
#
APP_URL=http://localhost:5000

# FRONTEND_URL = where to redirect the user after payment completes.
#                During development: http://localhost:5500 (or wherever you serve index.html)
#                In production: https://yoursite.com
#
FRONTEND_URL=http://localhost:5500
