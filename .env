# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
FLASK_ENV=development

# ── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string before deploying to production.
JWT_SECRET=change-this-to-a-long-random-secret-in-production
TOKEN_EXPIRY_HOURS=24

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=ecommerce

# ── OTP via Twilio (optional) ─────────────────────────────────────────────────
# Leave blank to use console/print mode during development.
# Get credentials from https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_EXPIRY_MINUTES=10

# ── Admin seed account ────────────────────────────────────────────────────────
# Used only on first startup to create the default admin.
# Change these before going to production.
ADMIN_EMAIL=admin@freshmart.com
ADMIN_PASSWORD=Admin@1234

# ── Instamojo Payment Gateway ─────────────────────────────────────────────────
#
INSTAMOJO_CLIENT_ID=V57r9Q83Cr9CUWSg4l84x8iQvOsUi8kmLlgYKws9
INSTAMOJO_CLIENT_SECRET=DBQMBBVOCBUlsdD5CED0gp3arKtfBOwAcQRS00xUHUF7VIL7h8k3GsE3wKWNJxptQ0hBcCqYbGHGxtW8pyaAPoer6xhTDydbaZ3CGeyRsKBQy17YKPXYj8hGM4uh1ZZZ
INSTAMOJO_SALT=a704487366ed4a3f9e1c58a48c7e7d8c

# Use test URL during development. Switch to https://api.instamojo.com for live.
INSTAMOJO_BASE_URL=https://api.instamojo.com

# Set INSTAMOJO_MOCK=true to skip real Instamojo calls during local testing.
# Orders will be marked confirmed immediately. Remove when going live.
INSTAMOJO_MOCK=false

# ── URLs ──────────────────────────────────────────────────────────────────────
# APP_URL: Your Flask backend URL. Instamojo uses this for webhook + redirect.
#   Local dev:   use ngrok → https://abc123.ngrok.io
#   Production:  https://api.yoursite.com
APP_URL=https://b3c4-2405-201-e026-501c-9c35-808-d8d-3ae4.ngrok-free.app

# FRONTEND_URL: Where to redirect users after payment completes.
#   Local dev:   http://localhost:5500
#   Production:  https://yoursite.com
FRONTEND_URL=http://localhost:5500/frontend
