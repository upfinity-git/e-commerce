# ── Server ────────────────────────────────────────────────
PORT=5000
FLASK_ENV=development

# ── Security ──────────────────────────────────────────────
# CHANGE THIS to a long random string before deploying!
JWT_SECRET=change-this-to-a-long-random-secret-in-production
TOKEN_EXPIRY_HOURS=24

# ── Database ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=ecommerce

# ── OTP (Twilio) ──────────────────────────────────────────
# Sign up at https://www.twilio.com and fill these in.
# OTP will fall back to console-print mode if these are blank.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OTP expires after this many minutes
OTP_EXPIRY_MINUTES=10

# ── Admin seed account ────────────────────────────────────
# Used only on first startup. Change before going to production.
ADMIN_EMAIL=admin@freshmart.com
ADMIN_PASSWORD=Admin@1234